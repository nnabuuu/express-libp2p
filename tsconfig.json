{
    "compilerOptions": {
      "target": "ES2023",
      "module": "ESNext",
      "moduleResolution": "Node",
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "strict": true,
      "skipLibCheck": true,
      "rootDir": "./src",
      "outDir": "./dist",
      "downlevelIteration": true
    },
    "include": ["src/**/*.ts"],
    "exclude": [
      "**/*.spec.ts",
      "**/*.test.ts"
    ]
  }